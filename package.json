{
	"name": "obs-studio",
	"version": "4.0.0-beta1",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"postinstall": "husky",
		"format": "prettier -w .",
		"package": "run build && companion-module-build",
		"build": "rimraf dist && run build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "run lint:raw .",
		"test": "vitest --run"
	},
	"license": "MIT",
	"dependencies": {
		"@companion-module/base": "~2.0.4",
		"obs-websocket-js": "5.0.8"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-obs-studio.git"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.2",
		"@types/node": "^22.19.21",
		"@vitest/eslint-plugin": "^1.6.20",
		"eslint": "^10.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "^3.8.4",
		"rimraf": "^6.1.3",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.61.1",
		"vitest": "^4.1.9"
	},
	"engines": {
		"node": "^22.20",
		"yarn": "^4"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.17.0"
}
